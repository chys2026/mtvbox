<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 警告: 由于本应用为视频爬虫工具,需要访问各类视频源,故允许HTTP明文流量。
         生产环境建议仅开放可信域名。 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>